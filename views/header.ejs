 <% if(user){
    %>
    <header class="text-center p-8  border-b border-gray-300  w-full shadow-md flex justify-between">
             <h1 class="text-3xl font-extrabold text-blue-600 mb-2">File Uploader</h1>
        <div class="flex gap-2">
           

                    <a href="/log-out" 
                       class="bg-red-600 hover:bg-red-700 transition-colors px-2 sm:px-4 md:px-8 py-3 rounded-2xl flex items-center font-medium text-white">
                      LOG OUT
                    </a>
        </div>
    </header>
    <%
 }
 else {
    %>
    <header class="text-center p-4  border-b border-gray-300  w-full shadow-md flex justify-between">
        
        <h1 class="text-3xl font-extrabold text-blue-600 mb-2">File Uploader</h1>
        <div class="flex gap-2">
            <a
                    href="/login" 
                    class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-2xl flex items-center gap-3 text-white">
                        SIGN IN
                    </a>

                    <a href="/sign-up" 
                       class="bg-red-600 hover:bg-red-700 transition-colors px-2 sm:px-4 md:px-8 py-3 rounded-2xl flex items-center font-medium text-white">
                      SIGN UP
                    </a>
        </div>
        
    </header>
    <%
 }
 %>