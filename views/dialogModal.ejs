 <div 
 id="dialogModal" 
 class="hidden fixed inset-0 bg-black/70 flex items-center justify-center ">
   
    <dialog 
    id="dialog"
    class="justify-self-center self-center bg-white rounded-3xl shadow-2xl max-w-md w-full  overflow-hidden">
     
        
        <!-- Body -->
        <form
         method="POST" 
        action="/folder/create"
        id="mydialogform"
        class="flex flex-col gap-4 rounded-3xl p-10 shadow-2xl">
        <div>
             <h1 class="text-gray-800 font-semibold text-lg">
            New Folder
        </h1>
        </div>
       
        <label 
        for="foldername" 
        class="block text-sm font-medium text-gray-800">Name</label>
                            <input 
                                id="foldername" 
                                name="foldername" 
                                type="text" 
                                class="w-full  border-2 border-[#54ACDB] rounded-2xl px-5 py-4 text-gray-800 placeholder-gray-500 focus:outline-none focus:border-blue-500 transition">
            <button 
                   type="submit"
                   class="bg-blue-600 hover:bg-blue-700 transition-colors py-2 px-4 rounded-2xl font-semibold text-lg text-white self-end"
                   >Create Folder</button>
        </form>

      
    </dialog>
</div>